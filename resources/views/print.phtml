                    <th><?= I18N::translate('Death Date') ?></th>
                <?php endif ?>
            </tr>
        </thead>
        <tbody>
            <?php foreach ($individuals as $individual) : ?>
                <tr>
                    <?php if ($sort_order === 'first_name') : ?>
                        <td><?= e($individual['first_name']) ?></td>
                        <td><?= e($individual['last_name']) ?></td>
                        <td><?= e($individual['birth_date']) ?></td>
                        <td><?= e($individual['death_date']) ?></td>
                    <?php elseif ($sort_order === 'birth_date') : ?>
                        <td><?= e($individual['birth_date']) ?></td>
                        <td><?= e($individual['last_name']) ?></td>
                        <td><?= e($individual['first_name']) ?></td>
                        <td><?= e($individual['death_date']) ?></td>
                    <?php else : ?>
                        <td><?= e($individual['last_name']) ?></td>
                        <td><?= e($individual['first_name']) ?></td>
                        <td><?= e($individual['birth_date']) ?></td>
                        <td><?= e($individual['death_date']) ?></td>
                    <?php endif ?>
                </tr>
            <?php endforeach ?>
        </tbody>
    </table>
