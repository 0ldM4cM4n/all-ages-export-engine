    <table>
        <thead>
            <tr>
                <?php if ($sort_order === 'first_name') : ?>
                    <th><?= I18N::translate('First Name') ?></th>
                    <th><?= I18N::translate('Last Name') ?></th>
                    <th><?= I18N::translate('Birth Date') ?></th>
                    <th><?= I18N::translate('Death Date') ?></th>
                <?php elseif ($sort_order === 'birth_date') : ?>
                    <th><?= I18N::translate('Birth Date') ?></th>
                    <th><?= I18N::translate('Last Name') ?></th>
                    <th><?= I18N::translate('First Name') ?></th>
                    <th><?= I18N::translate('Death Date') ?></th>
                <?php else : ?>
                    <th><?= I18N::translate('Last Name') ?></th>
                    <th><?= I18N::translate('First Name') ?></th>
